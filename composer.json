{
    "name": "wordpress/jwt-auth",
    "description": "OIDC / proxy JWT authentication for WordPress, configured via wp-config.php",
    "type": "wordpress-plugin",
    "version": "1.2.0",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "firebase/php-jwt": "*",
        "yahnis-elsts/plugin-update-checker": "^5.6"
    },
    "require-dev": {
        "php-stubs/wordpress-stubs": "^6.8",
        "php-stubs/woocommerce-stubs": "^10.9",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "replace": {
        "phpstan/phpstan": "*"
    },
    "autoload": {
        "psr-4": {
            "JwtAuth\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "phpstan": "phpstan analyse --memory-limit=2G"
    }
}
